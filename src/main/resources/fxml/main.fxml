<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainContainer" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.manuskript.MainController">
   <center>
      <!-- Haupt-Container -->
      <VBox spacing="10">
         <children>
      <!-- Verzeichnis-Auswahl -->
      <HBox spacing="10" alignment="CENTER_LEFT">
         <children>
            <Label text="Verzeichnis:" />
            <TextField fx:id="txtDirectoryPath" promptText="Wählen Sie ein Verzeichnis mit DOCX-Dateien" HBox.hgrow="ALWAYS" />
            <Button fx:id="btnSelectDirectory" text="Verzeichnis auswählen" />
            <Button fx:id="btnSplit" text="Kapitel-Split" prefWidth="120.0" />
         </children>
         <padding>
            <Insets bottom="5.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
      
      <!-- Downloads-Monitor entfernt - wird jetzt bei der rechten Tabelle platziert -->
      
      <!-- Filter und Sortierung entfernt - einfache Lösung -->
      
      <!-- Zwei Tabellen nebeneinander -->
      <HBox spacing="10" VBox.vgrow="ALWAYS">
         <children>
            <!-- Linke Tabelle: Verfügbare Dateien -->
            <VBox spacing="6" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Verfügbare Dateien:" styleClass="section-header" />
                  <HBox fx:id="downloadsMonitorContainer" spacing="8" alignment="CENTER_LEFT">
                     <children>
                        <CheckBox fx:id="chkDownloadsMonitor" text="📥 Downloads-Monitor: Neue Dateien automatisch überwachen" />
                     </children>
                  </HBox>
                  <TableView fx:id="tableViewAvailable" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colFileNameAvailable" text="Dateiname" prefWidth="200.0" id="colFileNameAvailable" />
                      <TableColumn fx:id="colFileSizeAvailable" text="Größe" prefWidth="80.0" id="colFileSizeAvailable" />
                      <TableColumn fx:id="colLastModifiedAvailable" text="Geändert" prefWidth="120.0" id="colLastModifiedAvailable" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
            
            <!-- Mittlere Buttons -->
            <VBox spacing="10" alignment="CENTER">
               <children>
                  <Button fx:id="btnAddToSelected" text="→" prefWidth="60.0" prefHeight="40.0" minWidth="60.0" minHeight="40.0" />
                  <Button fx:id="btnRemoveFromSelected" text="←" prefWidth="60.0" prefHeight="40.0" minWidth="60.0" minHeight="40.0" />
               </children>
            </VBox>
            
            <!-- Rechte Tabelle: Ausgewählte Dateien -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Ausgewählte Dateien:" styleClass="section-header" />
                  <Label text="Datei verschieben mit CTRL-Pfeiltaste" styleClass="info-text" />
                  <Label text="Extern geänderte Dateien werden mit einem ! markiert" styleClass="info-text" style="-fx-padding: 0 0 4 0;" />
                  <TableView fx:id="tableViewSelected" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colFileNameSelected" text="Dateiname" prefWidth="200.0" id="colFileNameSelected" />
                      <TableColumn fx:id="colFileSizeSelected" text="Größe" prefWidth="80.0" id="colFileSizeSelected" />
                      <TableColumn fx:id="colLastModifiedSelected" text="Geändert" prefWidth="120.0" id="colLastModifiedSelected" />
                      <TableColumn fx:id="colNotesSelected" text="Notizen" prefWidth="200.0" id="colNotesSelected" />
                    </columns>
                  </TableView>

               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="5.0" left="10.0" right="10.0" />
         </padding>
      </HBox>
         </children>
      </VBox>
   </center>
   <bottom>
      <!-- Toolbar: gruppierte Aktionen, einheitliche Button-Optik -->
      <VBox styleClass="main-toolbar" spacing="6" prefHeight="70">
         <children>
            <!-- Erste Reihe -->
            <HBox alignment="CENTER" spacing="0">
               <children>
                  <!-- Gruppe Projekt -->
                  <HBox styleClass="action-group" spacing="4" alignment="CENTER_LEFT">
                     <Button fx:id="btnDeleteFile" styleClass="main-toolbar-button" text="📁 Archivieren" minWidth="100">
                        <tooltip><Tooltip text="Ausgewählte Datei (es geht nur um nicht mehr benötigte docx links) ins Archiv verschieben" /></tooltip>
                     </Button>
                     <Button fx:id="btnNewChapter" styleClass="main-toolbar-button" text="📝 Neues Kapitel" minWidth="100">
                        <tooltip><Tooltip text="Neues Kapitel anlegen" /></tooltip>
                     </Button>
                  </HBox>
                  <Separator orientation="VERTICAL" styleClass="toolbar-separator" />
                  <!-- Gruppe Export -->
                  <HBox styleClass="action-group" spacing="6" alignment="CENTER_LEFT">
                     <Button fx:id="btnProcessSelected" styleClass="main-toolbar-button" text="📤 Buch exportieren" minWidth="120">
                        <tooltip><Tooltip text="Buch exportieren" /></tooltip>
                     </Button>
                     <Button fx:id="btnAudiobook" styleClass="main-toolbar-button" text="🎧 Hörbuch" minWidth="80">
                        <tooltip><Tooltip text="Ausgewählte Kapitel mit TTS zu einer Hörbuch-MP3 zusammenfügen" /></tooltip>
                     </Button>
                  </HBox>
                  <!-- Gruppe Sonstiges -->
                  <HBox styleClass="action-group" spacing="6" alignment="CENTER_LEFT">
                     <Button fx:id="btnThemeToggle" styleClass="main-toolbar-button" text="☀" minWidth="30">
                        <tooltip><Tooltip text="Theme wechseln" /></tooltip>
                     </Button>
                     <Button fx:id="btnSearchAllFiles" styleClass="main-toolbar-button" text="🔍 Suchen" minWidth="80">
                        <tooltip><Tooltip text="In allen Dateien der rechten Tabelle suchen" /></tooltip>
                     </Button>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="2.0" left="8.0" right="8.0" top="4.0" />
               </padding>
            </HBox>
            <!-- Zweite Reihe -->
            <HBox alignment="CENTER_LEFT" spacing="0" minHeight="36">
               <children>
                  <Region HBox.hgrow="ALWAYS" style="-fx-background-color: transparent;" />
                  <!-- Gruppe Bearbeiten - Zweite Reihe -->
                  <HBox styleClass="action-group" spacing="6" alignment="CENTER_LEFT">
                     <Button fx:id="btnProcessAll" styleClass="main-toolbar-button" text="✏️ Kapitel bearbeiten" minWidth="120">
                        <tooltip><Tooltip text="Ausgewählte Kapitel im Editor öffnen" /></tooltip>
                     </Button>
                     <Button fx:id="btnOnlineLektorat" styleClass="main-toolbar-button" text="📋 Online-Lektorat" minWidth="110">
                        <tooltip><Tooltip text="Online-Lektorat starten (API-Key unter Parameter → Online-Lektorat)" /></tooltip>
                     </Button>
                     <Button fx:id="btnOpenTtsEditor" styleClass="main-toolbar-button" text="🔊 Sprachsynthese" minWidth="120">
                        <tooltip><Tooltip text="Kapitel mit TTS bearbeiten: Text markieren, Sprachausgabe erzeugen" /></tooltip>
                     </Button>
                     <Button fx:id="btnWorldEditor" styleClass="main-toolbar-button" text="🌍 Welt-Editor" minWidth="120">
                        <tooltip><Tooltip text="Projekt-Kontextdateien bearbeiten (Charaktere, Welt, Kontext, etc.)" /></tooltip>
                     </Button>
                  </HBox>
                  <Region HBox.hgrow="ALWAYS" style="-fx-background-color: transparent;" />
               </children>
               <padding>
                  <Insets bottom="8.0" left="8.0" right="8.0" top="0.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </bottom>
</BorderPane> 